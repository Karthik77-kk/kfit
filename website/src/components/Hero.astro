---
const APK_URL = 'https://github.com/Karthik77-kk/karthik-fitness/releases/latest/download/app-release.apk';
---

<section class="hero" id="hero">
  <!-- Ambient background glows -->
  <div class="hero-glow hero-glow-green" aria-hidden="true"></div>
  <div class="hero-glow hero-glow-cyan" aria-hidden="true"></div>

  <div class="container hero-inner">
    <!-- ── Left: Copy ── -->
    <div class="hero-copy">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Free Forever &nbsp;·&nbsp; No Play Store &nbsp;·&nbsp; 100% Private
      </div>

      <h1 class="hero-title">
        <span class="line line1">Track smarter.</span>
        <span class="line line2 gradient-text">Lift heavier.</span>
        <span class="line line3">Lose fat.</span>
      </h1>

      <p class="hero-sub">
        Private AI fitness coaching built for Indian bodies.
        On-device Gemma&nbsp;3, real Indian foods, zero subscriptions — forever.
      </p>

      <div class="hero-actions">
        <a href={APK_URL} class="btn btn-primary btn-lg" download>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 16l-5-5 1.4-1.4 2.6 2.6V4h2v8.2l2.6-2.6L17 11l-5 5zm-7 4v-2h14v2H5z"/>
          </svg>
          Download APK
        </a>
        <a href="#features" class="btn btn-ghost btn-lg">
          See features
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="hero-trust">
        <div class="trust-item">
          <span class="trust-icon">🔒</span>
          <span>Private</span>
        </div>
        <div class="trust-dot"></div>
        <div class="trust-item">
          <span class="trust-icon">🤖</span>
          <span>On-device AI</span>
        </div>
        <div class="trust-dot"></div>
        <div class="trust-item">
          <span class="trust-icon">🇮🇳</span>
          <span>Indian foods</span>
        </div>
        <div class="trust-dot"></div>
        <div class="trust-item">
          <span class="trust-icon">⚡</span>
          <span>Android</span>
        </div>
      </div>
    </div>

    <!-- ── Right: Phone mockup ── -->
    <div class="hero-phone-area">
      <!-- Glow behind phone -->
      <div class="phone-halo" aria-hidden="true"></div>

      <!-- Floating badges -->
      <div class="float-badge badge-gemma">
        <span class="badge-icon">✨</span>
        <div>
          <div class="fb-title">Gemma 3 AI</div>
          <div class="fb-sub">Runs on-device</div>
        </div>
      </div>

      <div class="float-badge badge-offline">
        <span class="badge-icon">📴</span>
        <div>
          <div class="fb-title">100% Offline</div>
          <div class="fb-sub">No internet needed</div>
        </div>
      </div>

      <!-- Phone frame -->
      <div class="phone-wrapper" id="phoneWrapper">
        <div class="phone-frame">
          <!-- Notch -->
          <div class="phone-notch"></div>

          <!-- App screen -->
          <div class="phone-screen">
            <!-- Status bar -->
            <div class="ui-statusbar">
              <span class="ui-time">9:41</span>
              <div class="ui-status-icons">
                <svg width="15" height="11" viewBox="0 0 15 11" fill="white" opacity="0.8">
                  <rect x="0" y="4" width="3" height="7" rx="1"/>
                  <rect x="4" y="2.5" width="3" height="8.5" rx="1"/>
                  <rect x="8" y="1" width="3" height="10" rx="1"/>
                  <rect x="12" y="0" width="3" height="11" rx="1"/>
                </svg>
                <svg width="16" height="11" viewBox="0 0 24 12" fill="none" stroke="white" stroke-width="1.5" opacity="0.8">
                  <rect x="1" y="1" width="19" height="10" rx="2"/>
                  <rect x="2" y="2" width="13" height="8" rx="1" fill="white" stroke="none"/>
                  <path d="M22 4v4a2 2 0 000-4z" fill="white" stroke="none"/>
                </svg>
              </div>
            </div>

            <!-- Greeting -->
            <div class="ui-greeting">
              <div class="ui-date">Wednesday, June 4</div>
              <div class="ui-name-row">
                <span class="ui-name">Good morning, Karthik! 👋</span>
                <span class="ui-streak">🔥 12</span>
              </div>
            </div>

            <!-- AI Coach card -->
            <div class="ui-ai-card">
              <div class="ui-ai-icon">🤖</div>
              <div class="ui-ai-body">
                <div class="ui-ai-label">AI COACH</div>
                <div class="ui-ai-msg" id="uiAiMsg">You're in a 453 kcal deficit today. Keep it up! 💪</div>
              </div>
            </div>

            <!-- Rings -->
            <div class="ui-rings-wrap">
              <svg class="rings-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                <!-- Track (dim) -->
                <circle cx="100" cy="100" r="80" stroke="rgba(48,209,88,0.12)"  stroke-width="10" fill="none"/>
                <circle cx="100" cy="100" r="62" stroke="rgba(64,200,224,0.12)" stroke-width="10" fill="none"/>
                <circle cx="100" cy="100" r="44" stroke="rgba(255,159,10,0.12)" stroke-width="10" fill="none"/>
                <!-- Active rings (animated via JS) -->
                <circle class="ring-cal" cx="100" cy="100" r="80"
                  stroke="#30D158" stroke-width="10" fill="none"
                  stroke-dasharray="502" stroke-dashoffset="502"
                  stroke-linecap="round" transform="rotate(-90 100 100)"/>
                <circle class="ring-pro" cx="100" cy="100" r="62"
                  stroke="#40C8E0" stroke-width="10" fill="none"
                  stroke-dasharray="390" stroke-dashoffset="390"
                  stroke-linecap="round" transform="rotate(-90 100 100)"/>
                <circle class="ring-wat" cx="100" cy="100" r="44"
                  stroke="#FF9F0A" stroke-width="10" fill="none"
                  stroke-dasharray="276" stroke-dashoffset="276"
                  stroke-linecap="round" transform="rotate(-90 100 100)"/>
                <!-- Center text -->
                <text x="100" y="93" text-anchor="middle" fill="white"
                  font-size="22" font-weight="700" font-family="Inter, sans-serif">1,247</text>
                <text x="100" y="110" text-anchor="middle" fill="#8E8E93"
                  font-size="10" font-family="Inter, sans-serif">/ 1,700 kcal</text>
                <!-- Legend dots -->
                <circle cx="62" cy="170" r="4" fill="#30D158"/>
                <text x="70" y="174" fill="#8E8E93" font-size="9" font-family="Inter, sans-serif">Calories</text>
                <circle cx="107" cy="170" r="4" fill="#40C8E0"/>
                <text x="115" y="174" fill="#8E8E93" font-size="9" font-family="Inter, sans-serif">Protein</text>
              </svg>
            </div>

            <!-- Steps -->
            <div class="ui-steps">
              <div class="ui-steps-left">
                <span class="ui-steps-icon">🦶</span>
                <div>
                  <div class="ui-steps-val">6,234</div>
                  <div class="ui-steps-lbl">steps · 4.2 km</div>
                </div>
              </div>
              <div class="ui-steps-bar-wrap">
                <div class="ui-steps-bar">
                  <div class="ui-steps-fill" style="width:78%"></div>
                </div>
                <div class="ui-steps-pct">78%</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint">
    <div class="scroll-mouse">
      <div class="scroll-wheel"></div>
    </div>
    <span>Scroll to explore</span>
  </div>
</section>

<script>
  import gsap from 'gsap';

  // ── Entrance animation ────────────────────────────────────────────────────────
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  tl.from('.hero-badge',   { opacity: 0, y: 16, duration: 0.5 })
    .from('.line1',        { opacity: 0, y: 40, duration: 0.7 }, '-=0.2')
    .from('.line2',        { opacity: 0, y: 40, duration: 0.7 }, '-=0.55')
    .from('.line3',        { opacity: 0, y: 40, duration: 0.7 }, '-=0.55')
    .from('.hero-sub',     { opacity: 0, y: 24, duration: 0.6 }, '-=0.4')
    .from('.hero-actions', { opacity: 0, y: 20, duration: 0.6 }, '-=0.4')
    .from('.hero-trust',   { opacity: 0, duration: 0.5 }, '-=0.3')
    .from('.phone-wrapper',{ opacity: 0, y: 60, duration: 1.1 }, 0.4)
    .from('.phone-halo',   { opacity: 0, scale: 0.6, duration: 1.4, ease: 'power2.out' }, 0.5)
    .from('.badge-gemma',  { opacity: 0, x: 20, duration: 0.5 }, 1.2)
    .from('.badge-offline',{ opacity: 0, x: -20, duration: 0.5 }, 1.4)
    .from('.scroll-hint',  { opacity: 0, duration: 0.5 }, 1.6);

  // ── Ring fill animation ───────────────────────────────────────────────────────
  gsap.to('.ring-cal', { strokeDashoffset: 135, duration: 2.5, ease: 'power3.out', delay: 1.2 });
  gsap.to('.ring-pro', { strokeDashoffset: 125, duration: 2.5, ease: 'power3.out', delay: 1.4 });
  gsap.to('.ring-wat', { strokeDashoffset: 55,  duration: 2.5, ease: 'power3.out', delay: 1.6 });

  // ── 3D phone tilt on mousemove ────────────────────────────────────────────────
  const hero    = document.getElementById('hero');
  const wrapper = document.getElementById('phoneWrapper');

  hero?.addEventListener('mousemove', (e) => {
    const rect = hero.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width  - 0.5) * 2;
    const y = ((e.clientY - rect.top)  / rect.height - 0.5) * 2;

    gsap.to(wrapper, {
      rotateY:            x * 14,
      rotateX:           -y * 9,
      transformPerspective: 1000,
      duration: 0.5,
      ease: 'power2.out',
      overwrite: 'auto',
    });
  });

  hero?.addEventListener('mouseleave', () => {
    gsap.to(wrapper, {
      rotateY: -8, rotateX: 4,
      transformPerspective: 1000,
      duration: 1.5,
      ease: 'elastic.out(1, 0.6)',
    });
  });

  // ── Cycle AI messages ─────────────────────────────────────────────────────────
  const messages = [
    "You're in a 453 kcal deficit today. Keep it up! 💪",
    "Protein looks low — add 30g more to hit 100g target.",
    "12-day streak! Your consistency is paying off. 🔥",
    "At this pace you're losing ~0.5kg/week. Perfect! ✅",
    "Dinner idea: 2 chapati + dal = 360 kcal, 18g protein.",
  ];

  let idx = 0;
  const aiMsg = document.getElementById('uiAiMsg');

  function nextMsg() {
    if (!aiMsg) return;
    gsap.to(aiMsg, {
      opacity: 0, y: -6, duration: 0.25,
      onComplete: () => {
        idx = (idx + 1) % messages.length;
        aiMsg.textContent = messages[idx];
        gsap.to(aiMsg, { opacity: 1, y: 0, duration: 0.3 });
      },
    });
  }

  setInterval(nextMsg, 3200);

  // ── Scroll hint fade-out ──────────────────────────────────────────────────────
  window.addEventListener('scroll', () => {
    const hint = document.querySelector('.scroll-hint') as HTMLElement | null;
    if (hint) hint.style.opacity = String(Math.max(0, 1 - window.scrollY / 120));
  }, { passive: true });
</script>

<style>
  /* ── Section ──────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 0 80px;
    overflow: hidden;
  }

  /* ── Ambient glows ────────────────────────────────────────────────────────── */
  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .hero-glow-green {
    width: 700px; height: 700px;
    background: radial-gradient(ellipse, rgba(48,209,88,0.09) 0%, transparent 70%);
    top: -10%; right: -15%;
  }

  .hero-glow-cyan {
    width: 500px; height: 500px;
    background: radial-gradient(ellipse, rgba(64,200,224,0.07) 0%, transparent 70%);
    top: 20%; left: -10%;
  }

  /* ── Layout ───────────────────────────────────────────────────────────────── */
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 64px;
  }

  /* ── Copy ─────────────────────────────────────────────────────────────────── */
  .hero-copy { display: flex; flex-direction: column; gap: 28px; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
    width: fit-content;
  }

  .badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: dot-pulse 2s ease-in-out infinite;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero-title .line {
    display: block;
  }

  .hero-sub {
    font-size: 18px;
    color: var(--muted);
    max-width: 420px;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-lg { padding: 15px 28px; font-size: 15px; }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--muted);
  }

  .trust-icon { font-size: 14px; }

  .trust-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--muted2);
  }

  /* ── Phone area ───────────────────────────────────────────────────────────── */
  .hero-phone-area {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 60px 0;
  }

  .phone-halo {
    position: absolute;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(48,209,88,0.2) 0%, transparent 65%);
    animation: glow-pulse 4s ease-in-out infinite;
    pointer-events: none;
  }

  /* ── Floating badges ──────────────────────────────────────────────────────── */
  .float-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: rgba(28, 28, 30, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    z-index: 10;
    animation: badge-float 6s ease-in-out infinite;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  .badge-gemma {
    top: 8%;
    right: 2%;
    animation-delay: 0s;
  }

  .badge-offline {
    bottom: 12%;
    left: 0%;
    animation-delay: -3s;
  }

  .badge-icon { font-size: 22px; }

  .fb-title {
    font-size: 13px;
    font-weight: 600;
    color: white;
  }

  .fb-sub {
    font-size: 11px;
    color: var(--muted);
    margin-top: 1px;
  }

  /* ── Phone frame ──────────────────────────────────────────────────────────── */
  .phone-wrapper {
    position: relative;
    z-index: 5;
    animation: float 5s ease-in-out infinite;
    transform-style: preserve-3d;
    transform: perspective(1000px) rotateY(-8deg) rotateX(4deg);
    will-change: transform;
  }

  .phone-frame {
    width: 270px;
    background: #111113;
    border-radius: 46px;
    border: 1.5px solid rgba(255,255,255,0.12);
    box-shadow:
      0 50px 100px rgba(0,0,0,0.7),
      0 0 0 1px rgba(255,255,255,0.04),
      inset 0 0 0 1px rgba(255,255,255,0.06),
      0 0 60px rgba(48,209,88,0.12);
    overflow: hidden;
    position: relative;
  }

  .phone-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 28px;
    background: #111113;
    border-radius: 0 0 18px 18px;
    z-index: 10;
    border: 1.5px solid rgba(255,255,255,0.06);
    border-top: none;
  }

  /* ── App screen ───────────────────────────────────────────────────────────── */
  .phone-screen {
    background: #000;
    padding: 36px 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 560px;
  }

  .ui-statusbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 4px;
    margin-bottom: 2px;
  }

  .ui-time {
    font-size: 13px;
    font-weight: 600;
    color: white;
    letter-spacing: -0.02em;
  }

  .ui-status-icons { display: flex; align-items: center; gap: 4px; }

  /* Greeting */
  .ui-greeting { padding: 2px 4px; }

  .ui-date {
    font-size: 10px;
    color: var(--muted);
    margin-bottom: 2px;
  }

  .ui-name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .ui-name {
    font-size: 13px;
    font-weight: 700;
    color: white;
    letter-spacing: -0.02em;
  }

  .ui-streak {
    font-size: 11px;
    font-weight: 600;
    background: rgba(255,159,10,0.15);
    border: 1px solid rgba(255,159,10,0.3);
    color: #FF9F0A;
    padding: 2px 7px;
    border-radius: 100px;
  }

  /* AI card */
  .ui-ai-card {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 10px 12px;
    background: linear-gradient(135deg,
      rgba(48,209,88,0.12) 0%,
      rgba(64,200,224,0.06) 100%);
    border: 1px solid rgba(48,209,88,0.25);
    border-radius: 12px;
  }

  .ui-ai-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }

  .ui-ai-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--green);
    margin-bottom: 2px;
  }

  .ui-ai-msg {
    font-size: 11px;
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
  }

  /* Rings */
  .ui-rings-wrap {
    display: flex;
    justify-content: center;
    padding: 4px 0;
  }

  .rings-svg {
    width: 180px;
    height: 180px;
    filter: drop-shadow(0 0 12px rgba(48,209,88,0.2));
  }

  /* Steps */
  .ui-steps {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 8px 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
  }

  .ui-steps-left {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .ui-steps-icon { font-size: 16px; }

  .ui-steps-val {
    font-size: 13px;
    font-weight: 700;
    color: white;
  }

  .ui-steps-lbl {
    font-size: 9px;
    color: var(--muted);
  }

  .ui-steps-bar-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
  }

  .ui-steps-bar {
    width: 100%;
    height: 4px;
    background: rgba(255,255,255,0.08);
    border-radius: 2px;
    overflow: hidden;
  }

  .ui-steps-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--green), var(--cyan));
    border-radius: 2px;
    transition: width 1s ease;
  }

  .ui-steps-pct {
    font-size: 9px;
    color: var(--muted);
  }

  /* ── Scroll hint ──────────────────────────────────────────────────────────── */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--muted2);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: opacity 0.2s;
  }

  .scroll-mouse {
    width: 22px; height: 34px;
    border: 1.5px solid rgba(255,255,255,0.15);
    border-radius: 11px;
    display: flex;
    justify-content: center;
    padding-top: 5px;
  }

  .scroll-wheel {
    width: 3px; height: 7px;
    background: rgba(255,255,255,0.3);
    border-radius: 2px;
    animation: float 2s ease-in-out infinite;
  }

  /* ── Responsive ───────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-badge, .hero-title, .hero-trust { margin: 0 auto; }

    .hero-sub { max-width: none; }

    .hero-actions { justify-content: center; }

    .hero-trust { justify-content: center; }

    .hero-phone-area { order: -1; padding: 20px 0 0; }

    .badge-gemma  { right: 5%; top: 5%; }
    .badge-offline{ left: 5%; bottom: 5%; }
  }

  @media (max-width: 480px) {
    .phone-frame { width: 240px; }
  }
</style>
