---
const personas = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11h18M3 11a9 9 0 0 0 18 0M3 11C3 6.03 7.03 2 12 2s9 4.03 9 9M12 20v2M8 20h8"/></svg>`,
    accent: '#FF9F0A',
    title: 'You eat Indian food',
    desc: 'Tired of logging "white rice" and getting American macro estimates? K Fitness has 100+ real Indian foods with accurate macros — dal, chapati, idli, biryani.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    accent: '#30D158',
    title: 'You refuse to pay $15/month',
    desc: 'MyFitnessPal, Cronometer, Noom — they all charge. K Fitness is free. Not freemium. Not a trial. Free, forever, with no features locked behind a paywall.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
    accent: '#40C8E0',
    title: 'Privacy matters to you',
    desc: 'No account. No cloud sync. No data sold to advertisers. Your food logs, weight history, and AI conversations stay on your phone — permanently.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M5 8h14"/><path d="M7 8l1 8h8l1-8"/><path d="M10 16v5M14 16v5"/></svg>`,
    accent: '#BF5AF2',
    title: 'You want to recomp',
    desc: 'Lose fat while keeping muscle — the hardest thing in fitness. K Fitness tracks body fat %, FFMI, and deficit trends to tell you if you\'re actually succeeding.',
  },
];
---

<section class="section fyi-section">
  <div class="container">
    <div class="fyi-header">
      <span class="section-label">Who is this for</span>
      <h2>K Fitness is built for you<br/><span class="gradient-text">if any of this sounds familiar.</span></h2>
    </div>

    <div class="fyi-grid">
      {personas.map((p) => (
        <div class="fyi-card" style={`--accent:${p.accent}`}>
          <div class="fyi-icon" style={`color:${p.accent}`} set:html={p.icon}></div>
          <div class="fyi-content">
            <h3 class="fyi-title">{p.title}</h3>
            <p class="fyi-desc">{p.desc}</p>
          </div>
          <div class="fyi-accent-bar" style={`background:${p.accent}`}></div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.fyi-header', {
    y: 30, opacity: 0, duration: 0.8, ease: 'power2.out',
    scrollTrigger: { trigger: '.fyi-section', start: 'top 80%' },
  });

  gsap.from('.fyi-card', {
    y: 40, opacity: 0, duration: 0.7, stagger: 0.1, ease: 'power2.out',
    scrollTrigger: { trigger: '.fyi-grid', start: 'top 82%' },
  });

  document.querySelectorAll<HTMLElement>('.fyi-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      gsap.to(card, { y: -6, duration: 0.3, ease: 'power2.out' });
    });
    card.addEventListener('mouseleave', () => {
      gsap.to(card, { y: 0, duration: 0.4, ease: 'power2.out' });
    });
  });
</script>

<style>
  .fyi-section { padding-bottom: 40px; }

  .fyi-header { text-align: center; margin-bottom: 56px; }
  .fyi-header h2 { max-width: 600px; margin: 0 auto; }

  .fyi-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .fyi-card {
    position: relative;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow: hidden;
    transition: border-color 0.3s, background 0.3s;
    cursor: default;
  }

  .fyi-card::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 60% at 10% 10%, color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 70%);
    pointer-events: none;
    opacity: 0; transition: opacity 0.3s;
  }

  .fyi-card:hover {
    border-color: color-mix(in srgb, var(--accent) 25%, transparent);
    background: #202022;
  }

  .fyi-card:hover::before { opacity: 1; }

  /* Left accent bar */
  .fyi-accent-bar {
    position: absolute;
    left: 0; top: 20%; bottom: 20%;
    width: 3px; border-radius: 0 2px 2px 0;
    opacity: 0.7;
  }

  .fyi-icon {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
  }

  .fyi-icon svg { width: 32px; height: 32px; }

  .fyi-title {
    font-size: 18px; font-weight: 700;
    color: white; letter-spacing: -0.02em; line-height: 1.3;
  }

  .fyi-desc {
    font-size: 14px; color: var(--muted); line-height: 1.7;
  }

  @media (max-width: 700px) {
    .fyi-grid { grid-template-columns: 1fr; }
  }
</style>
