---
const APK_URL = 'https://github.com/Karthik77-kk/karthik-fitness/releases/latest/download/app-release.apk';
const GITHUB  = 'https://github.com/Karthik77-kk/karthik-fitness';
const YEAR    = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <div class="logo-mark">KF</div>
        <span>Karthik<span class="logo-accent">Fit</span></span>
      </a>
      <p class="footer-tagline">
        Private AI fitness tracker.<br/>
        Built in Bangalore. Free forever.
      </p>
      <div class="footer-socials">
        <a href={GITHUB} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer-links">
      <div class="link-col">
        <div class="link-col-title">App</div>
        <a href={APK_URL} download>Download APK</a>
        <a href={`${GITHUB}/releases`} target="_blank" rel="noopener noreferrer">Releases</a>
        <a href={`${GITHUB}`} target="_blank" rel="noopener noreferrer">Source code</a>
      </div>
      <div class="link-col">
        <div class="link-col-title">Features</div>
        <a href="#features">Overview</a>
        <a href="#ai-coach">AI Coach</a>
        <a href="#calculator">Calculator</a>
      </div>
      <div class="link-col">
        <div class="link-col-title">About</div>
        <a href={GITHUB} target="_blank" rel="noopener noreferrer">Karthik M</a>
        <a href={`${GITHUB}/issues`} target="_blank" rel="noopener noreferrer">Report a bug</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>© {YEAR} KarthikFit · Built in Bangalore 🇮🇳</span>
      <span class="footer-stack">Astro · GSAP · Cloudflare Pages</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    margin-top: 40px;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 64px;
    padding-top: 64px;
    padding-bottom: 48px;
  }

  /* Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: white;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.03em;
    width: fit-content;
  }

  .logo-mark {
    width: 34px; height: 34px;
    background: var(--green);
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 900;
    color: #000;
    letter-spacing: -0.5px;
  }

  .logo-accent { color: var(--green); }

  .footer-tagline {
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 240px;
  }

  .footer-socials { display: flex; gap: 12px; }

  .social-link {
    width: 36px; height: 36px;
    border-radius: 9px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    text-decoration: none;
    transition: all 0.2s;
  }

  .social-link:hover {
    color: white;
    border-color: var(--border-hi);
    background: rgba(255,255,255,0.08);
  }

  /* Links */
  .footer-links {
    display: flex;
    gap: 48px;
  }

  .link-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .link-col-title {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted2);
    margin-bottom: 4px;
  }

  .link-col a {
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
    width: fit-content;
  }

  .link-col a:hover { color: white; }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 20px 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: var(--muted2);
  }

  .footer-stack {
    font-size: 12px;
    opacity: 0.7;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-links { flex-wrap: wrap; gap: 32px; }
    .footer-bottom-inner { flex-direction: column; gap: 6px; text-align: center; }
  }
</style>
