<?xml version="1.0" encoding="utf-8"?>
<!--
    Multi-region widget layout on a translucent rounded panel.
    KFitnessWidgetProvider renders one Bitmap per region and wires its own
    PendingIntent per ImageView (each section is its own tap target).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:clipToOutline="true"
    android:padding="2dp">

    <!-- Date (right-aligned) -->
    <ImageView
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.55"
        android:scaleType="fitXY"
        android:background="@android:color/transparent"
        android:contentDescription="Date"/>

    <!-- Top row: cal/protein/water rings | water tile -->
    <LinearLayout
        android:id="@+id/widget_toprow"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3.1"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_rings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="56"
            android:scaleType="fitXY"
            android:background="@android:color/transparent"
            android:contentDescription="Calories, protein and water"/>

        <ImageView
            android:id="@+id/widget_water"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="44"
            android:scaleType="fitXY"
            android:background="@android:color/transparent"
            android:contentDescription="Water"/>

    </LinearLayout>

    <!-- Elongated live-steps card -->
    <ImageView
        android:id="@+id/widget_steps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.05"
        android:scaleType="fitXY"
        android:background="@android:color/transparent"
        android:contentDescription="Steps"/>

    <!-- Top-3 notifications -->
    <ImageView
        android:id="@+id/widget_notifs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.3"
        android:scaleType="fitXY"
        android:background="@android:color/transparent"
        android:contentDescription="Notifications"/>

</LinearLayout>
